{
    "name": "jccoca/laravel-api-exceptions",
    "description": "A clean and highly customizable REST API Exception Handler for Laravel.",
    "license": "MIT",
    "authors": [
        {
            "name": "José Coca Carrascosa Neto",
            "email": "jccoca.dev@gmail.com"
        }
